{
  "name": "astro-blog",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "A fast, minimal, fork-friendly blog template for Astro + MDX with a local admin panel.",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "bun": ">=1"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "sync": "astro sync",
    "check": "astro check && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "new-post": "bun run scripts/new-post.ts",
    "optimize-images": "python3 scripts/optimize-images.py",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.7.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@tailwindcss/vite": "^4.0.0",
    "@uiw/react-codemirror": "^4.25.0",
    "astro": "^6.1.9",
    "astro-expressive-code": "^0.41.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx,astro,mdx}": ["prettier --write", "eslint --fix"],
    "*.{css,json,md,yml,yaml}": ["prettier --write"]
  }
}
