---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="Not found" description="The page you're looking for doesn't exist." robots="noindex, follow">
  <div class="notfound">
    <div class="container notfound-inner">
      <p class="notfound-code" aria-hidden>404</p>
      <h1>Page not found</h1>
      <p class="notfound-desc">
        The URL you hit doesn't match anything here. Try the blog index or go home.
      </p>
      <div class="notfound-ctas">
        <a href="/" class="notfound-btn primary">Go home</a>
        <a href="/posts/" class="notfound-btn ghost">Browse posts</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem;
  }
  .notfound-inner {
    text-align: center;
    max-width: 34rem;
  }
  .notfound-code {
    font-size: clamp(5rem, 18vw, 9rem);
    font-weight: 800;
    line-height: 1;
    margin: 0 0 1rem;
    color: var(--color-border-hover);
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
  }
  h1 {
    font-size: 1.5rem;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
    font-weight: 600;
  }
  .notfound-desc {
    color: var(--color-text-secondary);
    margin: 0 0 2.5rem;
    font-size: 1rem;
    line-height: 1.55;
  }
  .notfound-ctas {
    display: inline-flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .notfound-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
  }
  .notfound-btn.primary {
    background: var(--color-accent);
    color: #fff;
    border: 1px solid transparent;
  }
  .notfound-btn.primary:hover { background: var(--color-accent-hover); }
  .notfound-btn.ghost {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
  .notfound-btn.ghost:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }
</style>
