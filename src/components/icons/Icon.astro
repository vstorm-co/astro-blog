const isFill = name.endsWith("-fill");
const d = paths[name];
---
{d && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill={isFill ? "currentColor" : "none"}
    stroke={isFill ? "none" : "currentColor"}
    stroke-width={isFill ? undefined : "2"}
    stroke-linecap={isFill ? undefined : "round"}
    stroke-linejoin={isFill ? undefined : "round"}
    class={className}
    {...rest}
    set:html={d}
  />
)}
