---
import type { Post } from "@/lib/posts";

export interface Props {
  prev: Post | null;
  next: Post | null;
}
const { prev, next } = Astro.props;
---
{(prev || next) && (
  <nav class="prev-next" aria-label="Adjacent posts">
    {prev ? (
      <a href={`/posts/${prev.id}/`} class="pn-card pn-prev">
        <span class="pn-label">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden>
            <path d="M8 3L4 6l4 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Previous
        </span>
        <span class="pn-title">{prev.data.title}</span>
      </a>
    ) : <span />}
    {next ? (
      <a href={`/posts/${next.id}/`} class="pn-card pn-next">
        <span class="pn-label">
          Next
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden>
            <path d="M4 3l4 3-4 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="pn-title">{next.data.title}</span>
      </a>
    ) : <span />}
  </nav>
)}

<style>
  .prev-next {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr 1fr;
    margin-top: 3rem;
  }
  .pn-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    transition: all 0.15s;
  }
  .pn-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .pn-next { text-align: right; }
  .pn-label {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .pn-next .pn-label { justify-content: flex-end; }
  .pn-title {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.015em;
  }
  .pn-card:hover .pn-title { color: var(--color-accent); }
  @media (max-width: 640px) {
    .prev-next { grid-template-columns: 1fr; }
    .pn-next { text-align: left; }
    .pn-next .pn-label { justify-content: flex-start; }
  }
</style>
