---
import { getAllPosts } from "@/lib/posts";
import Datetime from "./Datetime.astro";

export interface Props {
  currentId: string;
  tags: string[];
}

const { currentId, tags } = Astro.props;

const all = await getAllPosts();
const others = all.filter((p) => p.id !== currentId);

let related = others.filter((p) =>
  p.data.tags.some((t: string) => tags.includes(t))
);
if (related.length === 0) related = others;
const posts = related.slice(0, 3);
---
{posts.length > 0 && (
  <section class="related">
    <p class="related-title">Continue reading</p>
    <div class="related-grid">
      {posts.map((post) => (
        <a href={`/posts/${post.id}/`} class="related-card">
          <Datetime date={post.data.pubDate} class="related-date" />
          <h3 class="related-card-title">{post.data.title}</h3>
          <p class="related-card-desc">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .related-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-tertiary);
    margin: 0 0 1.25rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15rem), 1fr));
    gap: 1rem;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .related-card:hover { border-color: var(--color-border-hover); }
  .related-date {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }
  .related-card-title {
    font-size: 0.925rem;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    color: var(--color-text);
    transition: color 0.15s;
  }
  .related-card:hover .related-card-title { color: var(--color-accent); }
  .related-card-desc {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
