---
export interface Crumb {
  label: string;
  href?: string;
}

export interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {crumbs.map((c, i) => {
      const isLast = i === crumbs.length - 1;
      return (
        <li>
          {c.href && !isLast ? (
            <a href={c.href}>{c.label}</a>
          ) : (
            <span aria-current={isLast ? "page" : undefined}>{c.label}</span>
          )}
          {!isLast && (
            <svg class="sep" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden>
              <path d="M4 2l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    align-items: center;
  }
  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .breadcrumbs a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumbs a:hover { color: var(--color-accent); }
  .sep { color: var(--color-text-tertiary); opacity: 0.5; }
</style>
