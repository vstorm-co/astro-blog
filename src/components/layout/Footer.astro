---
import { SITE } from "@/site.config";
import { SOCIALS } from "@/socials";
import Icon from "@/components/icons/Icon.astro";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container site-footer-inner">
    <span class="site-footer-copy">© {year} {SITE.author}</span>
    <nav class="site-footer-links" aria-label="Social links">
      {SOCIALS.map((s) => (
        <a
          href={s.href}
          title={s.linkTitle}
          rel="me noopener noreferrer"
          target={s.href.startsWith("http") ? "_blank" : undefined}
          class="site-footer-icon-link"
          aria-label={s.linkTitle}
        >
          <Icon name={s.icon} size={16} aria-hidden="true" />
          <span class="sr-only">{s.name}</span>
        </a>
      ))}
    </nav>
    <a href="https://astro.build" rel="noopener" class="site-footer-astro" target="_blank">
      Built with Astro
    </a>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .site-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    flex-wrap: wrap;
  }
  .site-footer-copy { white-space: nowrap; }
  .site-footer-links {
    display: flex;
    gap: 0.25rem;
  }
  .site-footer-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 6px;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: all 0.15s;
  }
  .site-footer-icon-link:hover {
    color: var(--color-text-secondary);
    background: var(--color-surface);
  }
  .site-footer-astro {
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .site-footer-astro:hover { color: var(--color-text-secondary); }
  @media (max-width: 480px) {
    .site-footer-inner { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>
